# ─────────────────────────────────────────────────────────
# Personal Brand Agent — environment variables
# Copy to .env.local for `vercel dev`, or add to Vercel
# project settings for production.
# ─────────────────────────────────────────────────────────

# Supabase — create a free project at https://supabase.com
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 32-byte hex string used to encrypt API keys at rest.
# Generate with: openssl rand -hex 32
PA_ENCRYPTION_KEY=

# Comma-separated list of emails allowed to sign in, or "*" to allow anyone.
# Example: you@example.com,collab@example.com
PA_ALLOWED_EMAILS=you@example.com

# Canonical app URL (no trailing slash). Must match the domain
# you registered OAuth callbacks against.
# Example: https://yourdomain.com
PA_APP_URL=https://yourdomain.com
