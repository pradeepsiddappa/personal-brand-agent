# ─────────────────────────────────────────────
# Personal Agent — environment variables
# ─────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# In production, set these in Vercel project settings.

# Supabase ─────────────────────────────────────
# Create a project at https://supabase.com, then:
# Settings → API → copy these values
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Encryption ───────────────────────────────────
# 32-byte key (hex-encoded, 64 chars) for AES-256-GCM.
# Generate with: openssl rand -hex 32
# NEVER commit this. NEVER change this after saving keys (they'll be unreadable).
PA_ENCRYPTION_KEY=

# Allowlist ────────────────────────────────────
# Who can sign in with a magic link.
#   "you@example.com"                 → single user (default)
#   "you@example.com,friend@foo.com"  → multiple specific emails
#   "*"                               → anyone can sign up (OSS mode)
PA_ALLOWED_EMAILS=you@example.com

# App URL ──────────────────────────────────────
# Where the dashboard lives. Used for OAuth redirect URIs.
# No trailing slash.
PA_APP_URL=http://localhost:3000/pa

# ─────────────────────────────────────────────
# NOTE: The following are NOT env vars — users set these in
# the Settings tab of the dashboard (BYOK):
#   - Claude API key
#   - Twitter/X client ID + secret (from developer.x.com)
#   - Telegram bot token
#   - LinkedIn client ID + secret (v2)
# ─────────────────────────────────────────────
